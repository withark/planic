# ── NextAuth (Google 로그인) ──
# 운영: 실제 서비스 URL과 동일하게 설정 (예: https://www.planic.cloud). 코드에서 변경하지 않음.
NEXTAUTH_URL=https://www.planic.cloud
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# 로컬 개발 시 예시:
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=dev-secret-min-32-characters-long

# ── AI 엔진 (둘 중 하나만 있어도 됨) ──
# Anthropic (Claude) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# 모델 (선택). 기본값: claude-sonnet-4-6. 더 높은 품질 원하면 claude-opus-4-6
# ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# 사용할 모델 (선택, 기본값: gpt-4o)
# OPENAI_MODEL=gpt-4o

# 엔진 강제 선택 (선택): anthropic | openai
# 둘 다 키가 있으면 OPENAI_API_KEY가 있으면 openai, 없으면 anthropic
# AI_PROVIDER=openai

# 데이터 저장 경로 (기본값: ./data). 파일 기반은 단가/설정 등에만 사용. 견적 이력은 DB 사용.
DATA_DIR=./data

# ── DB (Neon Postgres, 운영 필수) ──
# 견적/히스토리는 사용자별로 여기에 저장됩니다.
# https://neon.tech 에서 프로젝트 생성 후 Connection string 복사
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── 결제 (Stripe, live 모드 시 필수) ──
# mock: 결제 없이 DB에만 구독 반영. live: 실제 Stripe 결제 + 웹훅 반영
BILLING_MODE=mock
# live 시 아래 변수 모두 필요
# Stripe 대시보드 > 개발자 > API 키 (시크릿 키), 웹훅 서명 시크릿
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe 상품/가격 생성 후 Price ID (가격: BASIC 월 19,900 / 연 198,000, PREMIUM 월 39,900 / 연 396,000 권장)
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...
# 결제 완료/취소 리다이렉트용 (미설정 시 NEXTAUTH_URL 또는 VERCEL_URL 사용)
# BILLING_BASE_URL=https://www.planic.cloud
